# ——— Local development (recommended) ———
# Relative URL uses Vite proxy → https://tabitayo-backend.onrender.com (see vite.config.ts)
VITE_API_URL=/api/v1
VITE_USE_MOCK=false
VITE_APP_URL=http://localhost:5173
VITE_PROXY_TARGET=https://tabitayo-backend.onrender.com

# ——— Direct API (only if backend CORS allows your exact origin) ———
# VITE_API_URL=https://tabitayo-backend.onrender.com/api/v1
# VITE_USE_MOCK=false

# ——— Mock mode (no backend) ———
# VITE_USE_MOCK=true

# ——— Vercel production ———
# Production builds default to Render API (mock OFF) even without these vars.
# Still set VITE_APP_URL for correct QR links:
#   VITE_APP_URL=https://your-domain.vercel.app
# Optional overrides:
#   VITE_API_URL=https://tabitayo-backend.onrender.com/api/v1
#   VITE_USE_MOCK=true   (only if you intentionally want mock on Vercel)
# Backend must allow CORS for your Vercel URL (*.vercel.app).
