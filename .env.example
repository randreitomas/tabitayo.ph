# ——— Local development (recommended) ———
# Relative URL uses Vite proxy → https://tabitayo-backend.onrender.com (see vite.config.ts)
VITE_API_URL=/api/v1
VITE_USE_MOCK=false
VITE_APP_URL=http://localhost:5173
VITE_PROXY_TARGET=https://tabitayo-backend.onrender.com

# ——— Direct API (only if backend CORS allows your exact origin) ———
# VITE_API_URL=https://tabitayo-backend.onrender.com/api/v1
# VITE_USE_MOCK=false

# ——— Mock mode (no backend) ———
# VITE_USE_MOCK=true

# ——— Vercel production ———
# vercel.json proxies /api/v1 → Render (no CORS setup needed).
# Set at minimum:
#   VITE_APP_URL=https://tabitayoph.vercel.app
# Optional (defaults shown):
#   VITE_API_URL=/api/v1
#   VITE_USE_MOCK=false
# Only use full Render URL if backend CORS allows your Vercel domain:
#   VITE_API_URL=https://tabitayo-backend.onrender.com/api/v1
